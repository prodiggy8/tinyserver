#!/usr/bin/env bash
# Run the full test suite; exits nonzero on failure.
set -euo pipefail

cd "$(dirname "$0")/.."

VENV_DIR=".venv"

if [ ! -x "$VENV_DIR/bin/pytest" ]; then
    python3 -m venv "$VENV_DIR"
    "$VENV_DIR/bin/pip" install -q --upgrade pip
    "$VENV_DIR/bin/pip" install -q pytest
fi

exec "$VENV_DIR/bin/pytest" "$@" tests/
